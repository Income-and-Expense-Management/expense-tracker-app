<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.QuanLiChiTieu" parent="Theme.MaterialComponents.DayNight.NoActionBar">
    </style>

    <style name="Theme.QuanLiChiTieu" parent="Base.Theme.QuanLiChiTieu" />

    <!--
        Native Splash Screen Theme (Android 12+ Splash Screen API compatible)
        This theme is applied to the launcher activity to show a green background
        during the initial cold start before the activity renders.

        For Android 12+, the system automatically uses android:windowSplashScreenBackground.
        For older versions, android:windowBackground provides the fallback.
    -->
    <style name="Theme.QuanLiChiTieu.Splash" parent="Theme.QuanLiChiTieu">
        <!-- Pre-Android 12: Solid green background during app launch -->
        <item name="android:windowBackground">@color/splash_background_green</item>
        <!-- Android 12+ Splash Screen API -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="s">@color/splash_background_green</item>
        <!-- Ensures status bar matches the splash background -->
        <item name="android:statusBarColor">@color/splash_background_green</item>
        <item name="android:navigationBarColor">@color/splash_background_green</item>
    </style>

    <!-- Segmented Button Style for Week/Month Toggle (Dark Theme) -->
    <style name="Widget.App.SegmentedButton" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="backgroundTint">@color/segmented_button_bg</item>
        <item name="android:textColor">@color/segmented_button_text</item>
        <item name="strokeWidth">0dp</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="elevation">0dp</item>
        <item name="rippleColor">@android:color/transparent</item>
    </style>

</resources>