<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.QuanLiChiTieu" parent="Theme.MaterialComponents.DayNight.NoActionBar">
    </style>

    <style name="Theme.QuanLiChiTieu" parent="Base.Theme.QuanLiChiTieu" />

    <!--
        Native Splash Screen Theme (Android 12+ Splash Screen API compatible)
        This theme is applied to the launcher activity to show a green background
        during the initial cold start before the activity renders.

        For Android 12+, the system automatically uses android:windowSplashScreenBackground.
        For older versions, android:windowBackground provides the fallback.
    -->
    <style name="Theme.QuanLiChiTieu.Splash" parent="Theme.QuanLiChiTieu">
        <!-- Pre-Android 12: Solid green background during app launch -->
        <item name="android:windowBackground">@color/splash_background_green</item>
        <!-- Android 12+ Splash Screen API -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="s">@color/splash_background_green</item>
        <!-- Ensures status bar matches the splash background -->
        <item name="android:statusBarColor">@color/splash_background_green</item>
        <item name="android:navigationBarColor">@color/splash_background_green</item>
    </style>

    <!-- Segmented Button Style for Week/Month Toggle (Dark Theme) -->
    <style name="Widget.App.SegmentedButton" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="backgroundTint">@color/segmented_button_bg</item>
        <item name="android:textColor">@color/segmented_button_text</item>
        <item name="strokeWidth">0dp</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="elevation">0dp</item>
        <item name="rippleColor">@android:color/transparent</item>
    </style>

    <!-- Full Screen Dialog Theme for Add Budget -->
    <style name="FullScreenDialogTheme" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">#0A0A0C</item>
    </style>

    <!-- Bottom Sheet Dialog Theme -->
    <style name="BottomSheetDialogTheme" parent="Theme.MaterialComponents.DayNight.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <style name="BottomSheetStyle" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="shapeAppearanceOverlay">@style/BottomSheetShapeAppearance</item>
    </style>

    <style name="BottomSheetShapeAppearance" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">20dp</item>
        <item name="cornerSizeTopRight">20dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- Date Picker Dialog Theme -->
    <style name="DatePickerDialogTheme" parent="ThemeOverlay.MaterialComponents.Dialog">
        <item name="colorPrimary">#4CAF50</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="android:windowBackground">@color/home_card_bg_dark</item>
    </style>

</resources>