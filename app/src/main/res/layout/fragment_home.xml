<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nestedScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    tools:context=".ui.home.HomeFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Green Header Background -->
        <View
            android:id="@+id/headerBackground"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="@drawable/bg_header_gradient"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Header: Title & Icons -->
        <TextView
            android:id="@+id/tvHomeTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:text="Hello Duy!"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/imgBell"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="24dp"
            android:src="@drawable/ic_bell"
            app:layout_constraintBottom_toBottomOf="@+id/tvHomeTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tvHomeTitle" />

        <ImageView
            android:id="@+id/imgSearch"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="20dp"
            android:src="@drawable/ic_search"
            app:tint="@color/white"
            app:layout_constraintBottom_toBottomOf="@+id/tvHomeTitle"
            app:layout_constraintEnd_toStartOf="@+id/imgBell"
            app:layout_constraintTop_toTopOf="@+id/tvHomeTitle" />

        <!-- Black main area overlapping the green background -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/mainContentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_main_curved"
            android:paddingBottom="24dp"
            app:layout_constraintTop_toBottomOf="@+id/tvHomeTitle"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Total Balance Section -->
            <TextView
                android:id="@+id/tvBalanceLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:text="@string/total_balance_label"
                android:textColor="#CCFFFFFF"
                android:textSize="18sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvBalanceValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/total_balance_value"
                android:textColor="@color/white"
                android:textSize="36sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="@+id/tvBalanceLabel"
                app:layout_constraintTop_toBottomOf="@+id/tvBalanceLabel" />

            <!-- My Wallet Section -->
            <TextView
                android:id="@+id/tvLabelWallet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:text="@string/my_wallet"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvBalanceValue" />

            <TextView
                android:id="@+id/tvSeeAllWallets"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="@string/see_all"
                android:textColor="@color/home_accent_green"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintBaseline_toBaselineOf="@+id/tvLabelWallet"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Wallet Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardWallet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card_dark_rounded"
                android:padding="16dp"
                android:elevation="4dp"
                app:layout_constraintTop_toBottomOf="@+id/tvLabelWallet">

                <ImageView
                    android:id="@+id/imgWalletIcon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_circle_dark"
                    android:padding="10dp"
                    android:src="@drawable/ic_payment_method"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvWalletDetailName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/wallet_name_a"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/imgWalletIcon"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvWalletDetailValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/wallet_amount_value"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Monthly Report Section -->
            <TextView
                android:id="@+id/tvLabelReport"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                android:text="@string/this_month_report"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cardWallet" />

            <TextView
                android:id="@+id/tvSeeDetailsReport"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="@string/see_details"
                android:textColor="@color/home_accent_green"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintBaseline_toBaselineOf="@+id/tvLabelReport"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Report Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardReport"
                android:layout_width="match_parent"
                android:layout_height="400dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card_dark_rounded"
                android:paddingTop="20dp"
                android:paddingBottom="42dp"
                android:elevation="4dp"
                app:layout_constraintTop_toBottomOf="@+id/tvLabelReport">

                <!-- Summary Row -->
                <LinearLayout
                    android:id="@+id/layoutSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    app:layout_constraintTop_toTopOf="parent">

                    <!-- Tab Expense -->
                    <LinearLayout
                        android:id="@+id/tabExpense"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tổng đã chi"
                            android:textColor="@color/home_text_secondary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvTotalSpentValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="1,000,000 đ"
                            android:textColor="@color/home_expense_red"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <View
                            android:id="@+id/lineExpense"
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:layout_marginHorizontal="16dp"
                            android:layout_marginTop="16dp"
                            android:background="@color/home_expense_red" />
                    </LinearLayout>

                    <!-- Tab Income -->
                    <LinearLayout
                        android:id="@+id/tabIncome"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tổng thu"
                            android:textColor="@color/home_text_secondary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvTotalIncomeValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="500,000 đ"
                            android:textColor="#555555"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <View
                            android:id="@+id/lineIncome"
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:layout_marginHorizontal="16dp"
                            android:layout_marginTop="16dp"
                            android:background="#222222" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Chart -->
                <com.ptithcm.quanlichitieu.ui.common.SimpleLineChart
                    android:id="@+id/lineChart"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="16dp"
                    app:layout_constraintBottom_toTopOf="@+id/tvMon"
                    app:layout_constraintTop_toBottomOf="@+id/layoutSummary" />

                <!-- Days of Week Labels -->
                <TextView
                    android:id="@+id/tvMon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:text="MON"
                    android:textColor="#888888"
                    android:textSize="10sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TUE"
                    android:textColor="#888888"
                    android:textSize="10sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.2"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WED"
                    android:textColor="#888888"
                    android:textSize="10sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.4"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="THR"
                    android:textColor="#888888"
                    android:textSize="10sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.6"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FRI"
                    android:textColor="#888888"
                    android:textSize="10sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.8"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="SAT"
                    android:textColor="#888888"
                    android:textSize="10sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Top 3 Highest Expenses Section -->
            <TextView
                android:id="@+id/tvLabelTopExpenses"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                android:text="@string/top_expenses_label"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cardReport" />

            <TextView
                android:id="@+id/tvSeeAllExpenses"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="@string/see_all"
                android:textColor="@color/home_accent_green"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintBaseline_toBaselineOf="@+id/tvLabelTopExpenses"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Top Expenses List Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardTopExpenses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card_dark_rounded"
                android:padding="16dp"
                android:elevation="4dp"
                app:layout_constraintTop_toBottomOf="@+id/tvLabelTopExpenses">

                <!-- Segmented Toggle: Week / Month -->
                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/togglePeriod"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_segmented_toggle"
                    android:padding="4dp"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnWeek"
                        style="@style/Widget.App.SegmentedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:minWidth="90dp"
                        android:paddingHorizontal="24dp"
                        android:text="@string/period_week" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMonth"
                        style="@style/Widget.App.SegmentedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:minWidth="90dp"
                        android:paddingHorizontal="24dp"
                        android:text="@string/period_month" />

                </com.google.android.material.button.MaterialButtonToggleGroup>

                <!-- RecyclerView for Top Expenses -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTopExpenses"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/togglePeriod" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
