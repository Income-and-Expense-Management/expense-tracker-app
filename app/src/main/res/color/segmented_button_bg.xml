<?xml version="1.0" encoding="utf-8"?>
<!-- Color state list for segmented button background (dark theme) -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Selected/Checked state: Lighter grey background -->
    <item android:color="#3D3D3D" android:state_checked="true" />
    <!-- Default/Unselected state: Transparent (shows container bg) -->
    <item android:color="@android:color/transparent" />
</selector>
